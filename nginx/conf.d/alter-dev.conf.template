upstream alter-dev_backend {
    server ${BACKEND_HOST}:8080;
    keepalive 32;
}

server {
    listen        80;
    server_name   ${SERVER_NAME};

    # Health check endpoint per Nginx
    location /nginx-health {
        access_log off;
        return 200 "healthy\n";
        add_header Content-Type text/plain;
    }
    
    return        301 https://$server_name$request_uri;
  }

  server {
    listen 443 ssl;
    #http2 on;    
    server_name ${SERVER_NAME};  

    # SSL certificates (self-signed per sviluppo)
    ssl_certificate /etc/nginx/ssl/alter-dev.crt;
    ssl_certificate_key /etc/nginx/ssl/alter-dev.key;

    # SSL configuration
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;
    ssl_prefer_server_ciphers on;
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 10m;
    
    # Logs
    access_log /var/log/nginx/alter-dev-access.log;
    error_log /var/log/nginx/alter-dev-error.log;
    
    location / {
    
        # Debug headers
        add_header X-Debug-Host $host always;
        add_header X-Debug-Scheme $scheme always;
	
        proxy_pass http://alter-dev_backend;
    }
  }
